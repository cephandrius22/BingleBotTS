{
  "name": "binglebot-ts",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && npm run client:build",
    "test": "vitest run",
    "test:watch": "vitest",
    "client:dev": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "express": "^5.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.13",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
